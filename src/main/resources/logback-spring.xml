<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true">
	<!-- Configurable via env:
	     LOG_PATH=/path/to/logs
	     LOG_FILE=checkin
	-->
	<property name="LOG_PATH" value="${LOG_PATH:-./logs}"/>
	<property name="LOG_FILE" value="${LOG_FILE:-checkin}"/>

	<appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
		<encoder>
			<pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
		</encoder>
	</appender>

	<!-- Rolls every 24 hours (daily), keeps compressed backups -->
	<appender name="ROLLING_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
		<file>${LOG_PATH}/${LOG_FILE}.log</file>
		<encoder>
			<pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
		</encoder>

		<rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
			<fileNamePattern>${LOG_PATH}/archive/${LOG_FILE}.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
			<!-- keep 30 days of backups -->
			<maxHistory>30</maxHistory>
			<cleanHistoryOnStart>true</cleanHistoryOnStart>
		</rollingPolicy>
	</appender>

	<logger name="org.springframework" level="INFO"/>
	<logger name="org.hibernate" level="WARN"/>
	<logger name="com.checkin" level="INFO"/>

	<root level="INFO">
		<appender-ref ref="CONSOLE"/>
		<appender-ref ref="ROLLING_FILE"/>
	</root>
</configuration>


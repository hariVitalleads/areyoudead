meta {
  name: Update Details
  type: http
  seq: 2
}

put {
  url: http://localhost:8080/checkin/api/user/details
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "email": "updated@example.com",
    "firstName": "Jane",
    "lastName": "Doe",
    "mobileNumber": "+1234567890",
    "inactivityThresholdDays": 7,
    "alertChannelPreference": "BOTH"
  }
}
